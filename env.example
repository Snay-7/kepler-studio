# Copy this file to `.env.local` for local development.
# In Vercel, add these as Environment Variables in: Project → Settings → Environment Variables.
#
# Note: because this is a static site, the values are exposed to the browser at runtime.
# That's fine for the SUPABASE_URL and the SUPABASE_ANON key — anon is designed to be public,
# and Row Level Security in `supabase-schema.sql` is what actually keeps your data safe.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON=eyJhbG...your-anon-key-here
